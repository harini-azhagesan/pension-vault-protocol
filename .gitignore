# ===========================
# PensionVault - .gitignore
# ===========================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
artifacts/
cache/
typechain-types/

# Environment variables (NEVER commit these)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Local prototype data (JSON files with user data)
server/data/*.json
!server/data/.gitkeep

# Hardhat local deployments
blockchain/deployments/
blockchain/.openzeppelin/

# IDE / Editor files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Coverage
coverage/
.nyc_output

# Misc
.gemini/
